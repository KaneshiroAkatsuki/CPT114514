{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "OMM日报系统",
  "version": "5.0.17",
  "identifier": "com.kaneshiro.omm-report-v5",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OMM日报系统 v5.0.17",
        "width": 700,
        "height": 800,
        "minWidth": 700,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/generate_report"
    ],
    "resources": [
      "resources/template.xlsx",
      "resources/tools/edge-cleaner/clean-edge.ps1",
      "resources/tools/edge-cleaner/clean-edge.bat"
    ]
  }
}
