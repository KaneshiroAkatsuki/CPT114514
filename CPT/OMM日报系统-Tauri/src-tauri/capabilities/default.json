{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "identifier": "default",
  "description": "Default permissions for 玉衡山科学院管理厅",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/generate_report",
          "cmd": "$RESOURCE/generate_report.exe",
          "args": []
        }
      ]
    }
  ]
}
